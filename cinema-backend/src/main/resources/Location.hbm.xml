<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="ca.etsmtl.log660.cinema_backend.model.Location" table="LOCATION">
        <id name="idLocation" column="ID_LOCATION">
            <generator class="native"/>
        </id>
        <property name="dateLocation" column="DATE_LOCATION" type="date"/>
        <property name="dateRetourPrevue" column="DATE_RETOUR_PREVUE" type="date"/>
        <property name="dateRetourEffective" column="DATE_RETOUR_EFFECTIVE" type="date"/>
        <many-to-one name="client" column="ID_CLIENT" not-null="true"/>
        <many-to-one name="copie" column="ID_COPIE" not-null="true"/>
    </class>
</hibernate-mapping>
